# Copy this file to `.env` and fill in only the variables you actually use.
# `.env` is ignored by git and should keep the real secrets.

# PromptAgent / SeedAgent demo via Volcengine Ark or another OpenAI-compatible endpoint
DOUBAO_API_KEY=your_api_key_here
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_MODEL=your_model_name_here

# Generic OpenAI-compatible Chat Completions credentials
OPENAI_API_KEY=
OPENAI_BASE_URL=

# OpenAICUAAgent credentials
# This path requires a backend compatible with OpenAI Responses API computer-use flow.
OPENAI_API_KEY_CUA=
OPENAI_BASE_URL_CUA=

# Volcengine provider. Required when running with `--provider_name volcengine`.
# The Volcengine implementation reads VOLCENGINE_REGION from the environment.
VOLCENGINE_ACCESS_KEY_ID=<access-key-id>
VOLCENGINE_SECRET_ACCESS_KEY=<secret-access-key>
VOLCENGINE_REGION=<region-id>
VOLCENGINE_ZONE_ID=<zone-id>
VOLCENGINE_SUBNET_ID=<subnet-id>
VOLCENGINE_SECURITY_GROUP_ID=<security-group-id>
VOLCENGINE_INSTANCE_TYPE=<ecs-instance-type>
VOLCENGINE_IMAGE_ID=<custom-image-id>
VOLCENGINE_DEFAULT_PASSWORD=<instance-password>
VOLCENGINE_SYSTEM_VOLUME_SIZE=30

# Use 0 when the runner reaches ECS through its public EIP.
# Use 1 only when the runner is inside the same VPC and can reach private IPs.
VOLCENGINE_USE_PRIVATE_IP=0

# Keep 0 for benchmark runs so ECS and EIP are cleaned up.
# Set 1 only for temporary debugging; it can leave billable ECS instances running.
VOLCENGINE_KEEP_INSTANCE_ON_CLOSE=0
VOLCENGINE_EIP_RELEASE_WAIT_SECONDS=180

# Dynamic ECS creation still allocates public EIP by default.
# In pool mode, keep 1 only when the runner needs public access to ECS.
VOLCENGINE_ALLOCATE_PUBLIC_EIP=1
VOLCENGINE_ALLOCATE_RETRY_ATTEMPTS=10
VOLCENGINE_ALLOCATE_RETRY_SECONDS=15
VOLCENGINE_ALLOCATE_LOCK_PATH=/tmp/osworld_volcengine_allocate.lock

# Volcengine ECS pool mode for high-concurrency benchmark runs.
# Disabled by default. Enable only for tagged OSWorld pool instances.
VOLCENGINE_POOL_ENABLED=0
VOLCENGINE_POOL_NAME=osworld-cua
VOLCENGINE_POOL_SIZE=25
VOLCENGINE_POOL_REGISTRY_PATH=/tmp/osworld_volcengine_pool.json
VOLCENGINE_POOL_LOCK_PATH=/tmp/osworld_volcengine_pool.lock
VOLCENGINE_POOL_ACQUIRE_WAIT_SECONDS=600
VOLCENGINE_POOL_ACQUIRE_POLL_SECONDS=5

# Reinstall/reset controls used only by Volcengine pool mode.
# 5 is the verified stable setting; use 15 only for a separate reinstall stress run.
VOLCENGINE_REINSTALL_WAIT_SECONDS=600
VOLCENGINE_REINSTALL_POLL_SECONDS=10
VOLCENGINE_READY_WAIT_SECONDS=300
VOLCENGINE_READY_POLL_SECONDS=5
VOLCENGINE_REINSTALL_RETRY_ATTEMPTS=5
VOLCENGINE_REINSTALL_RETRY_SECONDS=15
VOLCENGINE_REINSTALL_RETRY_MAX_SECONDS=90
VOLCENGINE_REINSTALL_CONCURRENCY=5
VOLCENGINE_REINSTALL_LOCK_DIR=/tmp/osworld_volcengine_reinstall_locks
VOLCENGINE_REINSTALL_SEMAPHORE_WAIT_SECONDS=3600

# CUA blackbox runtime
# These paths are machine-local. Do not copy another user's absolute paths.
OSWORLD_CUA_BIN=<path-to-cua-cli-or-bin.js>
OSWORLD_CUA_REPO_ROOT=<path-to-cua-repo>
OSWORLD_CUA_CONFIG_PATH=<path-to-cua-config-json>
OSWORLD_OPENCLAW_BIN=<osworld-repo>/osworld_cua_bridge/bin/openclaw
OSWORLD_CUA_VERSION=cua-local
OSWORLD_CUA_RUNS_DIR=
OSWORLD_CUA_MAX_DURATION_MS=600000
OSWORLD_CUA_MAX_STEP_DURATION_MS=60000
OSWORLD_CUA_TIMEOUT_GRACE_SECONDS=30

# Task-level proxy setup mode for proxy=true cases:
# auto: enable only for providers with supported proxy pools; vmware/volcengine default to direct network.
# on/off: force enable or disable task-level proxy setup.
OSWORLD_TASK_PROXY_MODE=auto

# Chrome CDP setup recovery. These apply to Chrome setup steps on any provider.
OSWORLD_CHROME_CDP_CONNECT_ATTEMPTS=15
OSWORLD_CHROME_CDP_RETRY_SECONDS=5
OSWORLD_CHROME_CDP_READY_TIMEOUT_SECONDS=3
OSWORLD_CHROME_CDP_RESTART_AFTER_ATTEMPTS=5
OSWORLD_AUTO_RESTART_CHROME_CDP=1

# Existing machines for local debug. These do not create or delete cloud resources.
# remote provider endpoint format:
# host:server_port:chromium_port:vnc_port:vlc_port
OSWORLD_REMOTE_UBUNTU_VM=<ubuntu-host>:5000:9222:8006:8080
OSWORLD_REMOTE_WINDOWS_VM=<windows-host>:5000:9222:8006:8080
OSWORLD_REMOTE_VM=

# VMware Fusion local VM for Ubuntu debugging.
OSWORLD_VMWARE_UBUNTU_VMX=<path-to-ubuntu-vmx>
OSWORLD_VMWARE_VMX=
